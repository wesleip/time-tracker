# =============================================================================
# Time Tracker — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores antes de subir em produção
# =============================================================================

# --- Domínio (Caddy / HTTPS) -------------------------------------------------
DOMAIN=time-tracker.seudominio.com

# --- Banco de dados ----------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROQUE_por_senha_forte_aqui
POSTGRES_DB=time_tracker

# Deve corresponder a POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB acima
DATABASE_URL=postgresql://postgres:TROQUE_por_senha_forte_aqui@db:5432/time_tracker

# --- API ---------------------------------------------------------------------
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=TROQUE_por_segredo_aleatorio_minimo_32_chars
JWT_EXPIRE_MINUTES=10080
DEBUG=false

# Deve ser a URL pública da aplicação
CORS_ORIGINS=https://time-tracker.seudominio.com
